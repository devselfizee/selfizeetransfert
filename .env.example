# ==============================================================================
# Configuration de Selfizee Transfer
# ==============================================================================
# Copiez ce fichier vers .env et adaptez les valeurs à votre environnement.
# ==============================================================================

# --- Général ---
# Clé secrète pour le chiffrement des tokens JWT (générée automatiquement par setup.sh)
SECRET_KEY=changez-moi-avec-une-vraie-cle-secrete

# Mode de l'application : development, staging, production
APP_ENV=development

# Activer le mode debug (désactiver en production)
DEBUG=true

# URL de base de l'application
BASE_URL=https://transfer.selfizee.local

# --- Base de données PostgreSQL ---
# Hôte de la base de données (nom du service Docker)
DB_HOST=db

# Port de la base de données
DB_PORT=5432

# Nom de la base de données
DB_NAME=selfizee_transfer

# Utilisateur de la base de données
DB_USER=postgres

# Mot de passe de la base de données (changez en production !)
DB_PASSWORD=postgres

# URL complète de connexion à la base de données (construite automatiquement)
DATABASE_URL=postgresql://postgres:postgres@db:5432/selfizee_transfer

# --- Redis ---
# Hôte Redis (nom du service Docker)
REDIS_HOST=redis

# Port Redis
REDIS_PORT=6379

# URL complète de connexion Redis
REDIS_URL=redis://redis:6379/0

# --- Stockage des fichiers ---
# Répertoire de stockage des transferts
STORAGE_PATH=/storage/transfers

# Taille maximale d'un fichier individuel en octets (5 Go par défaut)
MAX_FILE_SIZE=5368709120

# Taille maximale totale d'un transfert en octets (10 Go par défaut)
MAX_TRANSFER_SIZE=10737418240

# Durée de rétention des fichiers en jours (7 jours par défaut)
FILE_RETENTION_DAYS=7

# --- Email (SMTP) ---
# Activer l'envoi d'emails
SMTP_ENABLED=false

# Serveur SMTP
SMTP_HOST=smtp.example.com

# Port SMTP (587 pour TLS, 465 pour SSL)
SMTP_PORT=587

# Utilisateur SMTP
SMTP_USER=noreply@selfizee.fr

# Mot de passe SMTP
SMTP_PASSWORD=changez-moi

# Utiliser TLS pour la connexion SMTP
SMTP_TLS=true

# Adresse email de l'expéditeur
SMTP_FROM=noreply@selfizee.fr

# Nom affiché de l'expéditeur
SMTP_FROM_NAME=Selfizee Transfer

# --- Sécurité ---
# Durée de validité du token JWT en minutes (24 heures par défaut)
JWT_EXPIRATION_MINUTES=1440

# Nombre maximal de tentatives de connexion avant blocage
MAX_LOGIN_ATTEMPTS=5

# Durée du blocage après trop de tentatives (en minutes)
LOGIN_LOCKOUT_MINUTES=15

# Origines autorisées pour CORS (séparées par des virgules)
CORS_ORIGINS=https://transfer.selfizee.local

# --- Celery (tâches asynchrones) ---
# URL du broker Celery (utilise Redis)
CELERY_BROKER_URL=redis://redis:6379/1

# URL du backend de résultats Celery
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Sauvegardes ---
# Répertoire des sauvegardes
BACKUP_DIR=./backups

# Nombre de sauvegardes à conserver
BACKUP_RETENTION=7
